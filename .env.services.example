# ============================================================
# GLOBAL CONFIGURATION
# ============================================================
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# SUPABASE CLIENT CONFIGURATION (Frontend Next.js)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://rtxgmcbltiebcbhhbkxu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_z0ej6TQG49MK7s_RiL-wyA_xEwm2AMH

# ============================================================
# DATABASE CONFIGURATION (Supabase PostgreSQL Connection)
# ============================================================
# NOTA: Tu arroba '@' en la contraseña fue codificada como '%40' para evitar errores de conexión.
DATABASE_URL=postgresql://postgres.rtxgmcbltiebcbhhbkxu:ken12shin%40*@aws-1-us-west-1.pooler.supabase.com:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=30000

# ============================================================
# REDIS CONFIGURATION
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CLUSTER=false

# ============================================================
# AUTH SERVICE (Port 3001)
# ============================================================
AUTH_PORT=3001
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
PASSWORD_SALT_ROUNDS=10
SESSION_TTL=2592000

# ============================================================
# PRODUCT SERVICE (Port 3002)
# ============================================================
PRODUCT_PORT=3002
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CATEGORIES=3600
CACHE_TTL_SEARCH=600
PRODUCT_PAGE_SIZE=20
SEARCH_MIN_LENGTH=2

# ============================================================
# CART SERVICE (Port 3003)
# ============================================================
CART_PORT=3003
CART_SESSION_TTL=604800
CART_MAX_ITEMS=100
PRODUCT_SERVICE_URL=http://product-service:3002

# ============================================================
# ORDER SERVICE (Port 3004)
# ============================================================
ORDER_PORT=3004
ORDER_LOCK_TIMEOUT=30000
INVENTORY_LOCK_TIMEOUT=10000
PAYMENT_LOCK_TIMEOUT=15000
PRODUCT_SERVICE_URL=http://product-service:3002
PAYMENT_SERVICE_URL=http://payment-service:3005
MAX_ORDER_AMOUNT=100000

# ============================================================
# PAYMENT & STRIPE SERVICE (Port 3005)
# ============================================================
PAYMENT_PORT=3005
PAYMENT_TIMEOUT=30000
IDEMPOTENCY_KEY_EXPIRY=3600
# Credenciales de Stripe unificadas
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_API_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================
# REVIEW SERVICE (Port 3006)
# ============================================================
REVIEW_PORT=3006
REVIEW_MIN_LENGTH=10
REVIEW_MAX_LENGTH=5000
REVIEW_MODERATION_ENABLED=true
RATING_CACHE_TTL=3600

# ============================================================
# SUPPORT SERVICE (Port 3007)
# ============================================================
SUPPORT_PORT=3007
TICKET_ASSIGNMENT_STRATEGY=round_robin
MAX_OPEN_TICKETS=1000
TICKET_RESPONSE_SLA=4h

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_AUTH=5
RATE_LIMIT_GENERAL=10
RATE_LIMIT_CHECKOUT=1
RATE_LIMIT_WINDOW=60

# ============================================================
# MONITORING & LOGGING
# ============================================================
LOG_DIR=./logs
SENTRY_DSN=
DATADOG_API_KEY=
PROMETHEUS_ENABLED=false

# ============================================================
# MULTI-TENANCY
# ============================================================
DEFAULT_TENANT_ID=tenant-default
TENANT_ISOLATION_STRATEGY=rls
MAX_TENANTS=100

# ============================================================
# SECURITY
# ============================================================
API_KEY_HEADER=X-API-Key
TENANT_ID_HEADER=X-Tenant-ID
USER_ID_HEADER=X-User-ID
USER_ROLE_HEADER=X-User-Role
SESSION_ID_HEADER=X-Session-ID
HTTPS_ONLY=false

# ============================================================
# FEATURE FLAGS
# ============================================================
FEATURE_PRODUCT_RECOMMENDATIONS=true
FEATURE_INVENTORY_RESERVATION=true
FEATURE_DYNAMIC_PRICING=false
FEATURE_ANALYTICS=true
FEATURE_2FA=false

# ============================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_PRODUCT_PAGE_SIZE=12
NEXT_PUBLIC_DEFAULT_TENANT_ID=tenant-default
NEXT_PUBLIC_ANALYTICS_ID=